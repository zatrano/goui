# Normalize line endings to LF so gofmt/golangci-lint stay consistent across OSes.
* text=auto eol=lf

*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf
go.work text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Binary assets must not be normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
